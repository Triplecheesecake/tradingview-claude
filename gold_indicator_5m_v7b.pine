//@version=6
indicator("MGC Gold - 5min v7b", overlay=true, max_bars_back=500)

// === EMAs ===
ema5  = ta.ema(close, 5)
ema13 = ta.ema(close, 13)
ema50 = ta.ema(close, 50)
vwap  = ta.vwap(hlc3)
rsi   = ta.rsi(close, 14)
atr   = ta.atr(14)
atr_avg = ta.sma(atr, 50)
avg_vol = ta.sma(volume, 20)

// === DAILY TREND ===
gold_d_close = request.security(syminfo.tickerid, "D", close)
gold_d_ema50 = request.security(syminfo.tickerid, "D", ta.ema(close, 50))
bull_regime  = gold_d_close > gold_d_ema50
bear_regime  = gold_d_close < gold_d_ema50

// === SESSIONS ===
asia         = not na(time("5", "1800-2359", "America/New_York"))
london_early = not na(time("5", "0000-0200", "America/New_York"))
us_open      = not na(time("5", "0930-1100", "America/New_York"))
us_midday    = not na(time("5", "1100-1330", "America/New_York"))
in_session   = asia or london_early or us_open or us_midday

// === FILTERS (Thursdays + November open for max signals) ===
no_wednesday = dayofweek != dayofweek.wednesday
news_day     = atr > atr_avg * 2.5

// === PIVOT DETECTION ===
pivot_l = ta.pivotlow(low,  3, 2)
pivot_h = ta.pivothigh(high, 3, 2)

// === W FORMATION (longs) ===
var float w_sl1 = na
var float w_sl2 = na
var float w_mid = na
if not na(pivot_l)
    w_sl2 := w_sl1
    w_sl1 := pivot_l
if not na(pivot_h)
    w_mid := pivot_h

w_valid = not na(w_sl1) and not na(w_sl2) and not na(w_mid)
  and w_sl1 > w_sl2 and w_mid > w_sl2 and close > w_mid and close > vwap

// === M FORMATION (shorts) ===
var float m_sh1 = na
var float m_sh2 = na
var float m_mid = na
if not na(pivot_h)
    m_sh2 := m_sh1
    m_sh1 := pivot_h
if not na(pivot_l)
    m_mid := pivot_l

m_valid = not na(m_sh1) and not na(m_sh2) and not na(m_mid)
  and m_sh1 < m_sh2 and m_mid < m_sh2 and close < m_mid and close < vwap

// === SIGNALS ===
vol_pressure = volume > avg_vol * 1.0
base_filters = in_session and not news_day and no_wednesday

long_signal  = w_valid and bull_regime and vol_pressure and rsi > 45 and rsi < 74 and base_filters
short_signal = m_valid and bear_regime and vol_pressure and rsi > 26 and rsi < 55 and base_filters

// === SL/TP LEVELS FOR DISPLAY (4:1 R:R) ===
long_sl  = long_signal  ? math.max(w_sl1 - atr * 0.5, close - atr * 2.5) : na
long_tp  = long_signal  ? close + (close - long_sl)  * 4.0 : na
short_sl = short_signal ? math.min(m_sh1 + atr * 0.5, close + atr * 2.5) : na
short_tp = short_signal ? close - (short_sl - close) * 4.0 : na

// === PLOTS ===
plot(ema5,  "EMA 5",  color.new(color.white,  0), 1)
plot(ema13, "EMA 13", color.new(color.red,    0), 1)
plot(ema50, "EMA 50", color.new(color.yellow, 0), 2)
plot(vwap,  "VWAP",   color.new(color.purple, 0), 2)

bgcolor(bull_regime ? color.new(color.green, 95) : na, title="Bull Regime (W longs)")
bgcolor(bear_regime ? color.new(color.red,   95) : na, title="Bear Regime (M shorts)")
bgcolor(asia        ? color.new(color.blue,  90) : na, title="Asia Session")
bgcolor(us_open     ? color.new(color.teal,  90) : na, title="US Open")
bgcolor(us_midday   ? color.new(color.green, 90) : na, title="US Midday")
bgcolor(news_day    ? color.new(color.red,   85) : na, title="News Day - No Trade")

plotchar(not na(pivot_l), "Swing Low",  "•", location.belowbar, color.aqua,   size=size.tiny)
plotchar(not na(pivot_h), "Swing High", "•", location.abovebar, color.orange,  size=size.tiny)

plotshape(long_signal,  "W LONG",  shape.triangleup,   location.belowbar, color.lime, size=size.normal)
plotshape(short_signal, "M SHORT", shape.triangledown,  location.abovebar, color.red,  size=size.normal)

plot(long_sl,  "Long SL",  long_signal  ? color.new(color.red,  0) : na, 1, plot.style_linebr)
plot(long_tp,  "Long TP",  long_signal  ? color.new(color.lime, 0) : na, 1, plot.style_linebr)
plot(short_sl, "Short SL", short_signal ? color.new(color.red,  0) : na, 1, plot.style_linebr)
plot(short_tp, "Short TP", short_signal ? color.new(color.lime, 0) : na, 1, plot.style_linebr)

// === ALERTS ===
alertcondition(long_signal,  "Gold 5m v7b - W LONG",  '{"symbol":"{{ticker}}","price":"{{close}}","high":"{{high}}","low":"{{low}}","volume":"{{volume}}","time":"{{time}}","interval":"{{interval}}","condition":"LONG - Gold 5m W formation"}')
alertcondition(short_signal, "Gold 5m v7b - M SHORT", '{"symbol":"{{ticker}}","price":"{{close}}","high":"{{high}}","low":"{{low}}","volume":"{{volume}}","time":"{{time}}","interval":"{{interval}}","condition":"SHORT - Gold 5m M formation"}')
alertcondition(long_signal or short_signal, "Gold 5m v7b - Any Signal", '{"symbol":"{{ticker}}","price":"{{close}}","high":"{{high}}","low":"{{low}}","volume":"{{volume}}","time":"{{time}}","interval":"{{interval}}","condition":"Gold 5m v7b signal - check chart for direction"}')

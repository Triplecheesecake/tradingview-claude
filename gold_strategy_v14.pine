//@version=6
strategy("MGC Gold - 15min v14", overlay=true, max_bars_back=500, initial_capital=50000, currency=currency.USD, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=1.50)

// === INDICATORS ===
vwap    = ta.vwap(hlc3)
ema9    = ta.ema(close, 9)
ema21   = ta.ema(close, 21)
ema50   = ta.ema(close, 50)
ema200  = ta.ema(close, 200)
atr     = ta.atr(14)
atr_avg = ta.sma(atr, 50)
avg_vol = ta.sma(volume, 20)
rsi     = ta.rsi(close, 14)

// === DAILY BIAS ===
gold_d_close = request.security(syminfo.tickerid, "D", close)
gold_d_ema50 = request.security(syminfo.tickerid, "D", ta.ema(close, 50))
gold_uptrend = gold_d_close > gold_d_ema50
ema20_1h     = request.security(syminfo.tickerid, "60", ta.ema(close, 20))
ema50_1h     = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
uptrend_1h   = ema20_1h > ema50_1h

// === SESSIONS ===
overnight_kz = not na(time("15", "0200-0900", "America/New_York"))
asia_kz      = not na(time("15", "2000-0200", "America/New_York"))
us_session   = not na(time("15", "0930-1330", "America/New_York"))
london_close = not na(time("15", "1430-1600", "America/New_York"))
dead_zone    = not na(time("15", "1500-2000", "America/New_York"))
in_kz        = overnight_kz or asia_kz
no_wednesday = dayofweek != dayofweek.wednesday
news_day     = atr > atr_avg * 2.5

// === LEVELS ===
prev_day_low  = request.security(syminfo.tickerid, "D", low[1])
nearest_round = math.round(close / 100) * 100
above_round   = nearest_round + 100

// === SHARED CONDITIONS ===
momentum_up = close > close[1]
strong_bar  = (close - open) > (high - low) * 0.4
upper_half  = close > low + (high - low) * 0.5

// === SIGNAL 1: INSTITUTIONAL (v13 filters + ATR-based 3:1 target) ===
pdl_swept          = low < prev_day_low or low[1] < prev_day_low
pdl_reclaim_strong = close > prev_day_low + atr * 0.3

institutional_long = pdl_swept
  and pdl_reclaim_strong
  and close > vwap
  and volume > avg_vol * 1.0
  and rsi > 40 and rsi < 75
  and momentum_up
  and strong_bar
  and upper_half
  and gold_uptrend
  and in_kz
  and not news_day
  and not dead_zone
  and no_wednesday
  and strategy.position_size == 0

// === SIGNAL 2: VWAP PULLBACK (unchanged) ===
was_above_vwap = close[2] > vwap[2]
touched_vwap   = low[1] <= vwap[1]
closing_above  = close > vwap
higher_low     = low > ta.lowest(low, 10) and low[1] <= vwap[1]
uptrend_15     = ema50 > ema200

vwap_long = was_above_vwap
  and touched_vwap
  and closing_above
  and higher_low
  and uptrend_15
  and uptrend_1h
  and gold_uptrend
  and rsi > 50 and rsi < 72
  and volume > avg_vol * 1.3
  and momentum_up
  and strong_bar
  and us_session
  and not news_day
  and no_wednesday
  and strategy.position_size == 0

// === SIGNAL 3: LONDON CLOSE (unchanged from v13) ===
at_ema_demand  = (low[1] <= ema9[1] and close > ema9) or (low[1] <= ema21[1] and close > ema21)
lc_pdl_reclaim = pdl_swept and pdl_reclaim_strong and close > vwap

london_close_long = (at_ema_demand or lc_pdl_reclaim)
  and strong_bar
  and upper_half
  and close > vwap
  and gold_uptrend
  and rsi > 40 and rsi < 72
  and volume > avg_vol * 1.0
  and london_close
  and not news_day
  and no_wednesday
  and strategy.position_size == 0

// === ENTRIES & EXITS ===
// Institutional: switched from round number target to 3:1 ATR-based R:R
// Round number could be only $50 away — institutional moves often go $200-$500+
if institutional_long
    sl = math.min(low, low[1]) - atr * 0.5
    tp = close + (close - sl) * 3.0
    strategy.entry("Inst", strategy.long)
    strategy.exit("Inst X", "Inst", stop=sl, limit=tp)

if vwap_long
    sl = vwap - atr * 1.0
    tp = ema50 > close ? ema50 : close + (close - sl) * 3.0
    strategy.entry("VWAP", strategy.long)
    strategy.exit("VWAP X", "VWAP", stop=sl, limit=tp)

if london_close_long
    sl = math.min(low, low[1]) - atr * 0.5
    tp = close + (close - sl) * 3.0
    strategy.entry("LC", strategy.long)
    strategy.exit("LC X", "LC", stop=sl, limit=tp)

// === PLOTS ===
plot(vwap,         "VWAP",    color.new(color.purple, 0), 2)
plot(ema9,         "EMA 9",   color.new(color.aqua,   0), 1)
plot(ema21,        "EMA 21",  color.new(color.yellow, 0), 1)
plot(ema50,        "EMA 50",  color.new(color.orange, 0), 1)
plot(ema200,       "EMA 200", color.new(color.white,  0), 1)
plot(prev_day_low, "PDL",     color.new(color.green,  0), 1, plot.style_linebr)

bgcolor(overnight_kz ? color.new(color.blue,   92) : na, title="London")
bgcolor(asia_kz      ? color.new(color.purple,  92) : na, title="Asia")
bgcolor(us_session   ? color.new(color.green,   92) : na, title="US Session")
bgcolor(london_close ? color.new(color.teal,    90) : na, title="London Close")
bgcolor(news_day     ? color.new(color.red,     85) : na, title="News Day")

plotshape(institutional_long, "INST", shape.triangleup, location.belowbar, color.yellow, size=size.large)
plotshape(vwap_long,          "VWAP", shape.triangleup, location.belowbar, color.lime,   size=size.normal)
plotshape(london_close_long,  "LC",   shape.triangleup, location.belowbar, color.aqua,   size=size.normal)

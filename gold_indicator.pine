//@version=6
indicator("MGC Gold - Best Strategy v6", overlay=true, max_bars_back=500)

// === INDICATORS ===
vwap    = ta.vwap(hlc3)
ema20   = ta.ema(close, 20)
ema50   = ta.ema(close, 50)
ema200  = ta.ema(close, 200)
atr     = ta.atr(14)
atr_avg = ta.sma(atr, 50)
avg_vol = ta.sma(volume, 20)
rsi     = ta.rsi(close, 14)

// === FILTERS ===
news_day     = atr > atr_avg * 2.5
gold_d_close = request.security(syminfo.tickerid, "D", close)
gold_d_ema50 = request.security(syminfo.tickerid, "D", ta.ema(close, 50))
gold_uptrend = gold_d_close > gold_d_ema50
ema20_1h     = request.security(syminfo.tickerid, "60", ta.ema(close, 20))
ema50_1h     = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
uptrend_1h   = ema20_1h > ema50_1h

// === SESSIONS ===
overnight_kz = not na(time("15", "0200-0900", "America/New_York"))
asia_kz      = not na(time("15", "2000-0200", "America/New_York"))
us_session   = not na(time("15", "0930-1330", "America/New_York"))
dead_zone    = not na(time("15", "1500-2000", "America/New_York"))
in_kz        = overnight_kz or asia_kz

// === LEVELS ===
prev_day_low  = request.security(syminfo.tickerid, "D", low[1])
nearest_round = math.round(close / 100) * 100
above_round   = nearest_round + 100

// === SIGNAL 1: INSTITUTIONAL ===
pdl_swept     = low < prev_day_low or low[1] < prev_day_low
pdl_reclaimed = close > prev_day_low
momentum_up   = close > close[1]
strong_bar    = (close - open) > (high - low) * 0.4

institutional_long = pdl_swept
  and pdl_reclaimed
  and close > vwap
  and volume > avg_vol * 1.0
  and rsi > 40 and rsi < 75
  and momentum_up
  and strong_bar
  and gold_uptrend
  and in_kz
  and not news_day
  and not dead_zone

// === SIGNAL 2: VWAP PULLBACK ===
was_above_vwap = close[2] > vwap[2]
touched_vwap   = low[1] <= vwap[1]
closing_above  = close > vwap
higher_low     = low > ta.lowest(low, 10) and low[1] <= vwap[1]
uptrend_15     = ema20 > ema50 and close > ema200

vwap_long = was_above_vwap
  and touched_vwap
  and closing_above
  and higher_low
  and uptrend_15
  and uptrend_1h
  and gold_uptrend
  and rsi > 50 and rsi < 72
  and volume > avg_vol * 1.3
  and momentum_up
  and strong_bar
  and us_session
  and not news_day

// === PLOTS ===
plot(vwap,         "VWAP",         color.new(color.purple, 0), 2)
plot(ema20,        "EMA 20",       color.new(color.blue,   0), 1)
plot(ema50,        "EMA 50",       color.new(color.orange, 0), 1)
plot(ema200,       "EMA 200",      color.new(color.white,  0), 2)
plot(prev_day_low, "Prev Day Low", color.new(color.green,  0), 1, plot.style_linebr)

bgcolor(overnight_kz ? color.new(color.blue,   92) : na, title="London Killzone")
bgcolor(asia_kz      ? color.new(color.purple,  92) : na, title="Asia Killzone")
bgcolor(us_session   ? color.new(color.green,   92) : na, title="US Session")
bgcolor(dead_zone    ? color.new(color.gray,    92) : na, title="Dead Zone")
bgcolor(news_day     ? color.new(color.red,     85) : na, title="News Day")

plotshape(institutional_long, "INSTITUTIONAL", shape.triangleup, location.belowbar, color.yellow, size=size.large)
plotshape(vwap_long,          "VWAP PULLBACK", shape.triangleup, location.belowbar, color.lime,   size=size.normal)

// === ALERTS ===
alertcondition(institutional_long, "INSTITUTIONAL Long", '{"symbol":"{{ticker}}","price":"{{close}}","high":"{{high}}","low":"{{low}}","volume":"{{volume}}","time":"{{time}}","exchange":"{{exchange}}","interval":"{{interval}}","condition":"LONG - Gold institutional prev day low sweep"}')
alertcondition(vwap_long,          "VWAP Long",          '{"symbol":"{{ticker}}","price":"{{close}}","high":"{{high}}","low":"{{low}}","volume":"{{volume}}","time":"{{time}}","exchange":"{{exchange}}","interval":"{{interval}}","condition":"LONG - Gold VWAP pullback W formation"}')
